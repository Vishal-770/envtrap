{
  "name": "envtrap",
  "version": "2.0.2",
  "description": "Zero-Configuration Runtime Secret Leak Detector for Node.js 18+",
  "main": "dist/index.js",
  "bin": {
    "envtrap": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && cp src/hooks.mjs dist/hooks.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "postinstall": ""
  },
  "keywords": ["security", "secrets", "env", "leak", "detector", "nodejs"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "4.1.2",
    "commander": "11.1.0",
    "dotenv": "16.3.1",
    "node-forge": "1.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
